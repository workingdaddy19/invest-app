# .env.example - 환경변수 형식 참고용 (커밋 가능)
# 실제 값은 .env 파일에 작성 (.gitignore에 반드시 추가)
# EKS 운영환경에서는 K8s Secret으로 주입 (.env 파일 사용 금지)

# ── MLFlow 접속 정보 (필수)
MLFLOW_TRACKING_URI=http://mlflow.mlflow.svc.cluster.local:80
MLFLOW_TRACKING_USERNAME=<mlflow-username>
MLFLOW_TRACKING_PASSWORD=<mlflow-password>

# ── 모델 설정 (선택 - 기본값 사용 가능)
MODEL_CLS_NAME=invest-crel-classification
MODEL_REG_NAME=invest-crel-regression
MODEL_ALIAS=champion

# ── AWS 설정
AWS_REGION=ap-northeast-2
AWS_DEFAULT_REGION=ap-northeast-2
S3_BUCKET=s3-an2-mlops
